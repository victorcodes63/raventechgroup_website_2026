# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 9. HOMEPAGE SECTION ORDER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Assemble in HomePageContent.tsx in this exact order:

  01. <Hero />               dark — H1, subline, CTA pair, scroll indicator
  02. <TrustBadges />        dark — client logo ticker strip
  03. <Problems />           dark — pain points ("here's what's broken")
  04. <Services />           dark — 6-card services grid
  05. <Bridge />             dark→light transition — "Why Raven" statement
  06. <Process />            dark — 4-step how we work
  07. <QuickFacts />         dark — 4 animated stat blocks
  08. <ServiceHighlights />  dark — featured service deep-dive
  09. <Industries />         dark — SACCOs, Fintechs, Growth-stage
  10. <CaseStudiesPreview /> light — 2-3 featured case study cards
  11. <Testimonials />       light — 3 client quotes
  12. <About />              dark — Victor / founder brief
  13. <PlaybooksTeaser />    dark — resources teaser
  14. <Newsletter />         dark — email capture
  15. <PrimaryCTA />         dark — "Start your project" final banner
  {/* Footer lives in layout.tsx */}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 10. SEO — REQUIRED ON EVERY PAGE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

METADATA TEMPLATE:

  export const metadata: Metadata = {
    title: '[Page] | Raven Tech Group',
    description: '[Max 155 chars. Include service + Kenya/Nairobi/Africa]',
    keywords: ['technology consultancy Kenya', 'IT consulting Nairobi', ...],
    openGraph: {
      title: '...',
      description: '...',
      url: 'https://raventechgroup.com/[path]',
      siteName: 'Raven Tech Group',
      type: 'website',
      locale: 'en_KE',
      images: [{ url: '/og/[page].png', width: 1200, height: 630 }],
    },
    twitter: { card: 'summary_large_image', title: '...', description: '...' },
    alternates: { canonical: 'https://raventechgroup.com/[path]' },
    robots: { index: true, follow: true },
  }

JSON-LD via StructuredData.tsx:
  Homepage:      Organization + WebSite
  Service pages: Service + BreadcrumbList
  Case studies:  Article + BreadcrumbList
  Blog posts:    BlogPosting + BreadcrumbList + Person
  Contact:       LocalBusiness (Westlands, Nairobi, Kenya)
  Audit:         Service

SITEMAP priorities:
  1.0 homepage | 0.9 services | 0.8 blog | 0.7 everything else

PERFORMANCE TARGETS (before any deployment):
  LCP < 2.5s | CLS < 0.1 | FID < 100ms | All Core Web Vitals green


