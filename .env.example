# Copy to .env.local at the project root (next to package.json). Next.js does not load env files from app/.
# Never commit .env.local.

DATABASE_URL=

NEXT_PUBLIC_SITE_URL=https://www.raventechgroup.com
NEXT_PUBLIC_GA_ID=

# Microsoft Bookings — /book page
# Per-service URLs open the correct Bookings flow (no re-selecting the service on Microsoft’s side).
# Optional: omit to use the defaults baked into lib/data/bookingServices.ts (BOOKING_URLS).
NEXT_PUBLIC_BOOKING_URL_DISCOVERY=https://outlook.office.com/book/RavenTechGroup1@raventechgroup.com/s/D2SQkWtFAEeI4P4-ATvQ6Q2?ismsaljsauthenabled
NEXT_PUBLIC_BOOKING_URL_TECHNICAL=https://outlook.office.com/book/RavenTechGroup1@raventechgroup.com/s/iKwYRXnezUGbQW2kMPcV5g2?ismsaljsauthenabled
NEXT_PUBLIC_BOOKING_URL_IN_PERSON=https://outlook.office.com/book/RavenTechGroup1@raventechgroup.com/s/ARgejIJ_yEWP0sJZjvC0XA2?ismsaljsauthenabled

# Fallback when a per-service URL is not set (e.g. old deploy). Defaults to discovery page in repo.
NEXT_PUBLIC_BOOKING_URL=https://outlook.office.com/book/RavenTechGroup1@raventechgroup.com/s/D2SQkWtFAEeI4P4-ATvQ6Q2?ismsaljsauthenabled
